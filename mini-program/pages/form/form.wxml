<view class="container">
  <view class="card">
    <view class="section-title">基本信息</view>
    <input class="input" placeholder="姓名" value="{{form.name}}" bindinput="setField" data-field="name" />
    <picker mode="selector" range="{{genderOptions}}" value="{{genderIndex}}" bindchange="setGender">
      <view class="input">性别：{{form.gender || '请选择'}}</view>
    </picker>
    <picker mode="selector" range="{{degreeOptions}}" value="{{degreeIndex}}" bindchange="setDegree">
      <view class="input">学历：{{form.degree || '请选择'}}</view>
    </picker>
    <input class="input" placeholder="手机（可选）" value="{{form.phone}}" bindinput="setField" data-field="phone" />
  </view>

  <view class="card">
    <view class="section-title">教育经历</view>
    <view wx:for="{{form.educations}}" wx:key="index">
      <input class="input" placeholder="学校" value="{{item.school}}" bindinput="setEdu" data-index="{{index}}" data-field="school" />
      <input class="input" placeholder="专业" value="{{item.major}}" bindinput="setEdu" data-index="{{index}}" data-field="major" />
      <input class="input" placeholder="学历" value="{{item.degree}}" bindinput="setEdu" data-index="{{index}}" data-field="degree" />
      <view style="display:flex; gap:16rpx;">
        <input class="input" placeholder="起 YYYY-MM" value="{{item.start}}" bindinput="setEdu" data-index="{{index}}" data-field="start" />
        <input class="input" placeholder="止 YYYY-MM 或 至今" value="{{item.end}}" bindinput="setEdu" data-index="{{index}}" data-field="end" />
      </view>
      <view class="btn-secondary" bindtap="removeEdu" data-index="{{index}}" style="margin-top:8rpx;">删除</view>
    </view>
    <view class="btn-secondary" bindtap="addEdu">+ 添加教育</view>
  </view>

  <view class="card">
    <view class="section-title">工作经历</view>
    <view wx:for="{{form.experiences}}" wx:key="index">
      <input class="input" placeholder="公司" value="{{item.company}}" bindinput="setExp" data-index="{{index}}" data-field="company" />
      <input class="input" placeholder="职位" value="{{item.title}}" bindinput="setExp" data-index="{{index}}" data-field="title" />
      <view style="display:flex; gap:16rpx;">
        <input class="input" placeholder="起 YYYY-MM" value="{{item.start}}" bindinput="setExp" data-index="{{index}}" data-field="start" />
        <input class="input" placeholder="止 YYYY-MM 或 至今" value="{{item.end}}" bindinput="setExp" data-index="{{index}}" data-field="end" />
      </view>
      <textarea class="input" placeholder="工作描述" value="{{item.desc}}" bindinput="setExp" data-index="{{index}}" data-field="desc" />
      <view class="btn-secondary" bindtap="removeExp" data-index="{{index}}" style="margin-top:8rpx;">删除</view>
    </view>
    <view class="btn-secondary" bindtap="addExp">+ 添加工作</view>
  </view>

  <view class="card">
    <view class="section-title">求职期望</view>
    <input class="input" placeholder="期望城市" value="{{form.expected.city}}" bindinput="setExpected" data-field="city" />
    <input class="input" placeholder="期望岗位" value="{{form.expected.position}}" bindinput="setExpected" data-field="position" />
    <view style="display:flex; gap:16rpx;">
      <input class="input" type="number" placeholder="薪资下限 K" value="{{form.expected.salary_min}}" bindinput="setExpected" data-field="salary_min" />
      <input class="input" type="number" placeholder="薪资上限 K" value="{{form.expected.salary_max}}" bindinput="setExpected" data-field="salary_max" />
    </view>
  </view>

  <view class="card">
    <view class="section-title">技能（逗号分隔）</view>
    <input class="input" placeholder="React, Vue, TypeScript" value="{{skillsInput}}" bindinput="setSkillsInput" />
  </view>

  <view class="btn-primary" bindtap="submit">生成简历</view>
</view>