.container { padding: 24rpx; padding-bottom: 96rpx; }
.section-title { font-size: 32rpx; font-weight: bold; margin-bottom: 16rpx; }

/* R94 大屏入口 */
.btn-bigscreen {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #e8f8f0 0%, #d4f4e0 100%);
  border: 2rpx solid #07c160;
  border-radius: 24rpx;
}
.bs-icon { font-size: 56rpx; }
.bs-text { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.bs-title { font-size: 32rpx; font-weight: 600; color: #07c160; }
.bs-hint { font-size: 24rpx; color: #555; }
.bs-arrow { font-size: 40rpx; color: #07c160; }