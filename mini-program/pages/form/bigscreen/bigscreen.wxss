/* R96 — 大屏填简历精致版
 *
 * 色板:
 *   主色 绿 #07c160 / 深 #00a854 / 浅 #e8f8f0
 *   灰系 1a1a1a (主文) / 555 (副) / 888 (提示) / ccc (边框) / f5f7fa (底)
 *   强调 蓝 #2563eb (链接) / 红 #fa5151 (警告)
 *
 * 设计要点:
 *   - Hero 渐变区 + 大标题
 *   - 步骤指示器 (圆点 + 连线)
 *   - 浮动 label 输入框
 *   - 大圆环完成度
 *   - 立体预览卡片
 */

page {
  --primary: #07c160;
  --primary-dark: #00a854;
  --primary-light: #e8f8f0;
  --primary-bg: #f0fff5;
  --text: #1a1a1a;
  --text-sub: #555;
  --text-hint: #888;
  --border: #e5e7eb;
  --bg: #f5f7fa;
  --card: #ffffff;
  --link: #2563eb;
  --error: #fa5151;
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0,0,0,0.10);
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 32rpx;
}

.bigscreen {
  min-height: 100vh;
  background: var(--bg);
  display: flex;
  flex-direction: column;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

/* ─── Hero ───────────────────────────────────────── */
.hero {
  background: linear-gradient(135deg, #07c160 0%, #00a854 50%, #008f4f 100%);
  padding: 56rpx 48rpx 96rpx;
  color: #fff;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: "";
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  border-radius: 50%;
}
.hero-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}
.hero-title {
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
  margin-bottom: 12rpx;
}
.hero-sub {
  font-size: 28rpx;
  opacity: 0.85;
}
.hero-close {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
  font-size: 44rpx;
  color: #fff;
  opacity: 0.8;
  padding: 12rpx;
  z-index: 2;
}

/* ─── 步骤指示器 (浮在 hero 下方) ───────────────────────── */
.stepper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: -56rpx 32rpx 0;
  padding: 24rpx 32rpx;
  background: var(--card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  position: relative;
  z-index: 1;
}
.stepper-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  position: relative;
}
.stepper-item:not(:last-child)::after {
  content: "";
  position: absolute;
  top: 24rpx;
  left: calc(50% + 32rpx);
  right: calc(-50% + 32rpx);
  height: 4rpx;
  background: var(--border);
  z-index: -1;
}
.stepper-item.done:not(:last-child)::after {
  background: var(--primary);
}
.stepper-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--bg);
  color: var(--text-hint);
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--border);
  transition: all 0.25s ease;
}
.stepper-item.active .stepper-circle {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
  box-shadow: 0 4rpx 12rpx rgba(7,193,96,0.35);
  transform: scale(1.1);
}
.stepper-item.done .stepper-circle {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}
.stepper-name {
  font-size: 22rpx;
  color: var(--text-hint);
  font-weight: 500;
}
.stepper-item.active .stepper-name,
.stepper-item.done .stepper-name {
  color: var(--text);
}

/* ─── 主区 ───────────────────────────────────────── */
.main {
  flex: 1;
  display: flex;
  padding: 32rpx;
  gap: 32rpx;
}
.bigscreen.wide .main { flex-direction: row; }
.bigscreen.narrow .main { flex-direction: column; }

.left-pane {
  flex: 1;
  background: var(--card);
  border-radius: var(--radius-lg);
  padding: 48rpx;
  box-shadow: var(--shadow-sm);
  min-height: 70vh;
}
.bigscreen.wide .left-pane { flex: 1.4; }

.right-pane {
  flex: 0.8;
  max-width: 480rpx;
}
.bigscreen.narrow .right-pane {
  flex: 1;
  max-width: 100%;
}

/* ─── 步骤 header ───────────────────────────────────────── */
.step-header {
  margin-bottom: 40rpx;
  padding-bottom: 32rpx;
  border-bottom: 2rpx solid var(--bg);
}
.step-num-badge {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 20rpx;
  background: var(--primary-light);
  color: var(--primary-dark);
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.step-title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -1rpx;
  line-height: 1.2;
}
.step-hint {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: var(--text-hint);
}

/* ─── 字段 (浮动 label) ───────────────────────────────────────── */
.field-float {
  position: relative;
  margin-bottom: 36rpx;
}
.field-float-label {
  position: absolute;
  top: 28rpx;
  left: 32rpx;
  font-size: 30rpx;
  color: var(--text-hint);
  pointer-events: none;
  transition: all 0.2s ease;
  background: transparent;
  padding: 0 8rpx;
}
.field-float.has-value .field-float-label,
.field-float-input:focus + .field-float-label {
  top: -10rpx;
  font-size: 22rpx;
  color: var(--primary);
  background: var(--card);
}
.field-float-input {
  width: 100%;
  min-height: 96rpx;
  padding: 28rpx 32rpx 12rpx;
  font-size: 36rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
  background: var(--card);
  box-sizing: border-box;
  color: var(--text);
  transition: border-color 0.2s ease;
}
.field-float-input:focus {
  border-color: var(--primary);
  outline: none;
  box-shadow: 0 0 0 6rpx rgba(7,193,96,0.08);
}
.field-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-hint);
}
.textarea-big {
  min-height: 200rpx;
  line-height: 1.5;
  padding-top: 36rpx;
}

/* ─── Chip (性别) ───────────────────────────────────────── */
.chips {
  display: flex;
  gap: 16rpx;
  margin-bottom: 36rpx;
}
.chip {
  flex: 1;
  padding: 32rpx;
  text-align: center;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-md);
  font-size: 32rpx;
  font-weight: 500;
  background: var(--card);
  color: var(--text-sub);
  transition: all 0.2s ease;
}
.chip-active {
  border-color: var(--primary);
  background: var(--primary);
  color: #fff;
  font-weight: 600;
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(7,193,96,0.25);
}

/* ─── Date row ───────────────────────────────────────── */
.date-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}
.date-input { flex: 1; min-width: 0; }
.date-sep {
  color: var(--text-hint);
  font-size: 28rpx;
  font-weight: 500;
}

/* ─── Repeat card (教育/工作) ───────────────────────── */
.repeat-card {
  background: var(--bg);
  padding: 32rpx;
  border-radius: var(--radius-md);
  margin-bottom: 24rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s ease;
}
.repeat-card:hover { border-color: var(--primary-light); }
.repeat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx dashed var(--border);
}
.repeat-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}
.repeat-card .field-float { margin-bottom: 24rpx; }

/* ─── 按钮 ───────────────────────────────────────── */
.btn-add {
  padding: 32rpx;
  text-align: center;
  border: 2rpx dashed var(--primary);
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 500;
  color: var(--primary);
  background: var(--primary-bg);
  margin-bottom: 48rpx;
  transition: all 0.2s ease;
}
.btn-add:active {
  transform: scale(0.98);
  background: var(--primary-light);
}
.btn-link {
  font-size: 26rpx;
  color: var(--error);
  padding: 8rpx 16rpx;
  font-weight: 500;
}
.step-nav {
  display: flex;
  gap: 24rpx;
  margin-top: 56rpx;
  padding-top: 32rpx;
  border-top: 2rpx solid var(--bg);
}
.btn-primary {
  flex: 1;
  padding: 32rpx;
  text-align: center;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #fff;
  border-radius: var(--radius-md);
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  box-shadow: 0 6rpx 20rpx rgba(7,193,96,0.30);
  transition: all 0.2s ease;
}
.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(7,193,96,0.30);
}
.btn-secondary {
  padding: 32rpx 40rpx;
  text-align: center;
  background: var(--card);
  color: var(--text-sub);
  border-radius: var(--radius-md);
  font-size: 32rpx;
  font-weight: 500;
  border: 2rpx solid var(--border);
}
.btn-secondary:active {
  background: var(--bg);
}
.step-nav .submit {
  background: linear-gradient(135deg, #ff8c00 0%, #ff6b00 100%);
  box-shadow: 0 6rpx 20rpx rgba(255,107,0,0.30);
}

/* ─── 预览卡片 (右) ───────────────────────── */
.preview-card {
  background: var(--card);
  border-radius: var(--radius-lg);
  padding: 40rpx 36rpx;
  box-shadow: var(--shadow-md);
  position: sticky;
  top: 32rpx;
  border-left: 8rpx solid var(--primary);
}
.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid var(--bg);
}
.preview-name {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -1rpx;
}
.preview-completion {
  display: flex;
  align-items: baseline;
}
.completion-num {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--primary);
  letter-spacing: -2rpx;
}
.completion-pct {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 600;
  margin-left: 4rpx;
}
.preview-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 24rpx;
}
.preview-meta text:not(:first-child)::before {
  content: "·";
  margin-right: 8rpx;
}
.preview-section {
  margin-top: 20rpx;
}
.preview-section-title {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: var(--primary-dark);
  font-weight: 700;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}
.preview-section-title::before {
  content: "";
  width: 8rpx;
  height: 24rpx;
  background: var(--primary);
  margin-right: 12rpx;
  border-radius: 4rpx;
}
.preview-line {
  display: block;
  font-size: 28rpx;
  color: var(--text);
  margin-bottom: 4rpx;
  line-height: 1.5;
}
.preview-line-mini {
  display: block;
  font-size: 24rpx;
  color: var(--text-hint);
  margin-bottom: 4rpx;
  padding-left: 12rpx;
  line-height: 1.5;
}

/* ─── 响应式 ───────────────────────────────────────── */
@media (max-width: 1023px) {
  .hero { padding: 40rpx 32rpx 80rpx; }
  .hero-title { font-size: 44rpx; }
  .main { padding: 16rpx; }
  .left-pane { padding: 32rpx 24rpx; }
  .step-title { font-size: 44rpx; }
}