/* R94 大屏填简历 — 大字号 / 左输入右预览 / 自适应 */

/* ─── 基础 ───────────────────────────────────────── */
.bigscreen {
  min-height: 100vh;
  background: #f5f7fa;
  display: flex;
  flex-direction: column;
}

/* ─── 顶部 ───────────────────────────────────────── */
.topbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 48rpx;
  background: #fff;
  border-bottom: 1rpx solid #eaeaea;
}
.topbar-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.topbar-close {
  font-size: 40rpx;
  color: #999;
  padding: 16rpx;
  cursor: pointer;
}

/* ─── 进度条 ───────────────────────────────────────── */
.progress {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 48rpx;
  background: #fff;
  border-bottom: 1rpx solid #eaeaea;
}
.step-dot {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  opacity: 0.5;
  transition: opacity 0.2s;
}
.step-dot.active { opacity: 1; }
.step-num {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #e0e0e0;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}
.step-dot.active .step-num { background: #07c160; }
.step-name {
  font-size: 24rpx;
  color: #666;
}
.step-dot.active .step-name { color: #07c160; font-weight: 600; }

/* ─── 主区 ───────────────────────────────────────── */
.main {
  flex: 1;
  display: flex;
  overflow: hidden;
}
.bigscreen.wide .main { flex-direction: row; }
.bigscreen.narrow .main { flex-direction: column; }

.left-pane {
  flex: 1;
  padding: 48rpx;
  box-sizing: border-box;
}
.bigscreen.wide .left-pane { flex: 1; }
.bigscreen.narrow .left-pane { flex: 1; }

.right-pane {
  width: 480rpx;
  padding: 48rpx 48rpx 48rpx 0;
  box-sizing: border-box;
  overflow-y: auto;
}
.bigscreen.narrow .right-pane {
  width: 100%;
  padding: 0 48rpx 48rpx;
}

/* ─── 步骤 header ───────────────────────────────────────── */
.step-header {
  margin-bottom: 32rpx;
}
.step-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
}
.step-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #888;
}

/* ─── 大输入 ───────────────────────────────────────── */
.field-big {
  margin-bottom: 32rpx;
}
.field-label {
  display: block;
  font-size: 28rpx;
  color: #555;
  margin-bottom: 12rpx;
  font-weight: 500;
}
.field-input {
  width: 100%;
  min-height: 88rpx;
  padding: 24rpx 28rpx;
  font-size: 36rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  background: #fff;
  box-sizing: border-box;
  color: #1a1a1a;
}
.field-input:focus { border-color: #07c160; outline: none; }
.field-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}
.textarea-big {
  min-height: 200rpx;
  line-height: 1.5;
}
.picker {
  display: flex;
  align-items: center;
  color: #1a1a1a;
}

/* ─── Chip (性别) ───────────────────────────────────────── */
.gender-row {
  display: flex;
  gap: 16rpx;
}
.chip {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  font-size: 32rpx;
  background: #fff;
  color: #555;
}
.chip-active {
  border-color: #07c160;
  background: #07c160;
  color: #fff;
  font-weight: 600;
}

/* ─── Date row ───────────────────────────────────────── */
.date-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}
.date-input { flex: 1; min-width: 0; }
.date-sep {
  color: #999;
  font-size: 28rpx;
}

/* ─── Repeat card (教育/工作) ───────────────────────────────────────── */
.repeat-card {
  background: #fff;
  padding: 32rpx;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.repeat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.repeat-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

/* ─── 按钮 ───────────────────────────────────────── */
.btn-add {
  padding: 24rpx;
  text-align: center;
  border: 2rpx dashed #07c160;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #07c160;
  background: #f0fff5;
  margin-bottom: 48rpx;
}
.btn-primary {
  padding: 28rpx;
  text-align: center;
  background: #07c160;
  color: #fff;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  flex: 1;
}
.btn-secondary {
  padding: 28rpx;
  text-align: center;
  background: #fff;
  color: #555;
  border-radius: 16rpx;
  font-size: 32rpx;
  border: 2rpx solid #e0e0e0;
  flex: 1;
}
.btn-link {
  font-size: 26rpx;
  color: #fa5151;
  padding: 8rpx 16rpx;
}
.step-nav {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
}
.step-nav .submit { background: linear-gradient(135deg, #07c160 0%, #00a854 100%); }

/* ─── 预览卡片 ───────────────────────────────────────── */
.preview-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.08);
}
.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  border-bottom: 1rpx solid #eaeaea;
  padding-bottom: 24rpx;
  margin-bottom: 24rpx;
}
.preview-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
}
.preview-completion {
  display: flex;
  align-items: baseline;
}
.completion-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #07c160;
}
.completion-pct {
  font-size: 28rpx;
  color: #07c160;
  margin-left: 4rpx;
}
.preview-meta {
  display: flex;
  gap: 8rpx;
  font-size: 26rpx;
  color: #888;
  margin-bottom: 24rpx;
}
.preview-section {
  margin-top: 20rpx;
}
.preview-section-title {
  display: block;
  font-size: 26rpx;
  color: #07c160;
  font-weight: 600;
  margin-bottom: 8rpx;
  border-left: 6rpx solid #07c160;
  padding-left: 12rpx;
}
.preview-line {
  display: block;
  font-size: 28rpx;
  color: #1a1a1a;
  margin-bottom: 4rpx;
}
.preview-line-mini {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 4rpx;
  padding-left: 12rpx;
}