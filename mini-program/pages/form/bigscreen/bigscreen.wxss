/* R97 — AI 对话式填简历
 *
 * 设计: chat 气泡流
 *   - AI 气泡: 灰底 + 左圆角尖头 (左对齐)
 *   - User 气泡: 主色绿底 + 右圆角尖头 (右对齐)
 *   - 输入区: 底部固定, 大输入框
 *
 * 推翻传统: 无 form 表单 / 无卡片 / 无 stepper, 全 chat 流
 */

.bigscreen {
  min-height: 100vh;
  background: linear-gradient(180deg, #fafbfc 0%, #f0f4f8 100%);
  display: flex;
  flex-direction: column;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

/* ─── 顶部 header ───────────────────────────────────────── */
.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 40rpx;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
  position: sticky;
  top: 0;
  z-index: 10;
}
.chat-header-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.chat-header-icon {
  font-size: 56rpx;
  line-height: 1;
}
.chat-header-info {
  display: flex;
  flex-direction: column;
}
.chat-header-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: -0.5rpx;
}
.chat-header-progress {
  font-size: 22rpx;
  color: #888;
  margin-top: 4rpx;
}
.chat-header-close {
  font-size: 40rpx;
  color: #aaa;
  padding: 12rpx;
}

/* ─── 主区 ───────────────────────────────────────── */
.chat-main {
  flex: 1;
  display: flex;
  overflow: hidden;
}
.bigscreen.wide .chat-main { flex-direction: row; }
.bigscreen.narrow .chat-main { flex-direction: column; }

/* ─── 聊天流 ───────────────────────────────────────── */
.chat-stream {
  flex: 1;
  padding: 32rpx 24rpx 0;
  box-sizing: border-box;
}
.bigscreen.wide .chat-stream { flex: 1.5; }

.chat-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 200rpx; /* 给底部输入栏留空间 */
}

.msg-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  animation: msgIn 0.3s ease-out;
}
@keyframes msgIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.msg-row.ai { justify-content: flex-start; }
.msg-row.user { justify-content: flex-end; }

.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.msg-avatar.ai {
  background: linear-gradient(135deg, #07c160 0%, #00a854 100%);
  color: #fff;
}
.msg-avatar.user {
  background: #fff;
  color: #555;
  font-size: 24rpx;
  font-weight: 600;
  border: 2rpx solid #e5e7eb;
}

.msg-bubble {
  max-width: 70%;
  padding: 24rpx 32rpx;
  border-radius: 28rpx;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-word;
  position: relative;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.msg-bubble.ai {
  background: #fff;
  color: #1a1a1a;
  border-bottom-left-radius: 8rpx;
  font-size: 30rpx;
}
.msg-bubble.user {
  background: linear-gradient(135deg, #07c160 0%, #00a854 100%);
  color: #fff;
  border-bottom-right-radius: 8rpx;
  font-size: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(7,193,96,0.25);
}
.msg-bubble.current {
  border: 2rpx solid #07c160;
  animation: pulse 1.5s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(7,193,96,0.4); }
  50% { box-shadow: 0 0 0 12rpx rgba(7,193,96,0); }
}

.chat-end {
  width: 100%;
  height: 1rpx;
}

/* ─── 输入栏 (底部固定) ───────────────────────────────────────── */
.chat-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx 32rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(0,0,0,0.06);
  display: flex;
  gap: 16rpx;
  align-items: center;
  z-index: 20;
}
.bigscreen.wide .chat-input-bar {
  /* 在 wide 模式, 只覆盖左半边 (chat 区) */
  right: 40%; /* 留 40% 给 preview */
}

.chat-input {
  flex: 1;
  min-height: 80rpx;
  padding: 20rpx 28rpx;
  font-size: 30rpx;
  background: #f5f7fa;
  border: 2rpx solid transparent;
  border-radius: 24rpx;
  color: #1a1a1a;
  box-sizing: border-box;
  transition: border-color 0.2s ease;
}
.chat-input:focus {
  border-color: #07c160;
  background: #fff;
  outline: none;
}
.chat-textarea {
  min-height: 140rpx;
  line-height: 1.5;
  padding-top: 20rpx;
}

.chat-send {
  padding: 24rpx 36rpx;
  background: linear-gradient(135deg, #07c160 0%, #00a854 100%);
  color: #fff;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(7,193,96,0.25);
}
.chat-skip {
  padding: 24rpx 28rpx;
  color: #888;
  font-size: 26rpx;
  flex-shrink: 0;
}

.chat-chips {
  display: flex;
  gap: 16rpx;
  width: 100%;
}
.chat-chip {
  flex: 1;
  padding: 28rpx;
  text-align: center;
  background: #fff;
  border: 2rpx solid #e5e7eb;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 500;
  color: #555;
  transition: all 0.2s ease;
}
.chat-chip:active {
  background: #07c160;
  color: #fff;
  border-color: #07c160;
  transform: scale(0.97);
}

.chat-picker {
  padding: 28rpx 32rpx;
  background: #fff;
  border: 2rpx solid #e5e7eb;
  border-radius: 20rpx;
  font-size: 30rpx;
  color: #555;
  text-align: center;
}

.chat-date-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
  flex: 1;
}
.chat-date-input {
  flex: 1;
  min-height: 80rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  background: #f5f7fa;
  border: 2rpx solid transparent;
  border-radius: 20rpx;
  text-align: center;
}
.chat-date-input:focus {
  border-color: #07c160;
  background: #fff;
}
.chat-date-sep {
  color: #888;
  font-size: 26rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.chat-addmore {
  display: flex;
  gap: 16rpx;
  width: 100%;
}
.chat-addmore-btn {
  flex: 1;
  padding: 32rpx;
  text-align: center;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.2s ease;
}
.chat-addmore-btn.yes {
  background: linear-gradient(135deg, #07c160 0%, #00a854 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(7,193,96,0.25);
}
.chat-addmore-btn.no {
  background: #fff;
  color: #555;
  border: 2rpx solid #e5e7eb;
}

/* ─── 完成态 ───────────────────────────────────────── */
.chat-complete {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(0,0,0,0.06);
  text-align: center;
  z-index: 20;
}
.bigscreen.wide .chat-complete {
  right: 40%;
}
.chat-complete-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}
.chat-submit {
  display: inline-block;
  padding: 32rpx 80rpx;
  background: linear-gradient(135deg, #ff8c00 0%, #ff6b00 100%);
  color: #fff;
  border-radius: 32rpx;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  box-shadow: 0 6rpx 20rpx rgba(255,107,0,0.35);
}

/* ─── 浮动预览 (右) ───────────────────────────────────────── */
.chat-preview {
  width: 40%;
  padding: 32rpx 32rpx 32rpx 0;
  box-sizing: border-box;
  overflow-y: auto;
}

.preview-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.08);
  border-left: 8rpx solid #07c160;
  position: sticky;
  top: 32rpx;
}
.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 24rpx;
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid #f5f7fa;
}
.preview-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
}
.preview-completion {
  display: flex;
  align-items: baseline;
}
.completion-num {
  font-size: 56rpx;
  font-weight: 800;
  color: #07c160;
  letter-spacing: -2rpx;
}
.completion-pct {
  font-size: 28rpx;
  color: #07c160;
  font-weight: 600;
  margin-left: 4rpx;
}
.preview-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  font-size: 26rpx;
  color: #888;
  margin-bottom: 24rpx;
}
.preview-meta text:not(:first-child)::before {
  content: "·";
  margin-right: 8rpx;
}
.preview-section {
  margin-top: 20rpx;
}
.preview-section-title {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #00a854;
  font-weight: 700;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}
.preview-section-title::before {
  content: "";
  width: 8rpx;
  height: 24rpx;
  background: #07c160;
  margin-right: 12rpx;
  border-radius: 4rpx;
}
.preview-line {
  display: block;
  font-size: 28rpx;
  color: #1a1a1a;
  margin-bottom: 4rpx;
  line-height: 1.5;
}
.preview-line-mini {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 4rpx;
  padding-left: 12rpx;
}

/* ─── 响应式 (窄屏) ───────────────────────────────────────── */
@media (max-width: 1023px) {
  .chat-input-bar { right: 0; }
  .chat-complete { right: 0; }
  .chat-preview { width: 100%; padding: 0 32rpx 32rpx; }
}