/* R116 抖音式大屏 — 抖音黑底 + 大字 + 紫渐变 AI */

/* ─── R116: 抖音竖滑 feed 大屏 ───────────────────────── */
.feed-page {
  width: 100%;
  height: 100vh;
  background: #000000;
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
  overflow: hidden;
}
.feed-scroll {
  width: 100%;
  height: 100vh;
}
.feed-progress {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 32rpx 24rpx;
  position: sticky;
  top: 0;
  background: rgba(0,0,0,0.8);
  z-index: 10;
}
.feed-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  transition: all 300ms ease;
}
.feed-dot.active {
  width: 24rpx;
  height: 24rpx;
  background: #fbbf24;
  box-shadow: 0 0 16rpx rgba(251,191,36,0.6);
}
.feed-dot.done {
  background: #07c160;
}
.feed-progress-num {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  margin-left: 16rpx;
  font-weight: 500;
}
.feed-section {
  min-height: 80vh;
  padding: 64rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}
.feed-ai-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(99,102,241,0.3);
  opacity: 0.7;
  position: absolute;
  top: 64rpx;
  right: 32rpx;
}
.feed-section-name {
  font-size: 80rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 6rpx;
  text-shadow: 0 2rpx 12rpx rgba(0,0,0,0.6);
  margin-top: 16rpx;
}
.feed-fields {
  width: 100%;
  white-space: nowrap;
  margin-top: 32rpx;
}
.feed-field-card {
  display: inline-block;
  width: 320rpx;
  height: 200rpx;
  margin-right: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.05);
  border: 4rpx solid rgba(255,255,255,0.1);
  vertical-align: top;
  white-space: normal;
  overflow: hidden;
}
.feed-field-card.filled {
  background: rgba(7,193,96,0.1);
  border-color: rgba(7,193,96,0.4);
}
.feed-field-card.current {
  background: rgba(99,102,241,0.15);
  border-color: #6366f1;
  border-width: 6rpx;
  box-shadow: 0 0 32rpx rgba(99,102,241,0.5);
  transform: scale(1.05);
}
.feed-field-card.done {
  opacity: 0.6;
}
.feed-field-label {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
  margin-bottom: 16rpx;
}
.feed-field-value {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  word-break: break-all;
}
.feed-field-prompt {
  display: block;
  font-size: 64rpx;
  font-weight: 700;
  color: #6366f1;
  text-align: center;
  line-height: 80rpx;
}
.feed-footer {
  padding: 64rpx 0 200rpx;
  text-align: center;
}
.feed-footer-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.4);
}
.feed-input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: rgba(0,0,0,0.9);
  backdrop-filter: blur(20rpx);
  border-top: 2rpx solid rgba(255,255,255,0.1);
}
.feed-input {
  flex: 1;
  height: 88rpx;
  padding: 0 24rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 44rpx;
  color: #fff;
  font-size: 32rpx;
}
.feed-send-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 32rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

/* R118 T1: 简历预览卡 */
.feed-preview-card { position: fixed; right: 24rpx; bottom: 160rpx; width: 480rpx; max-height: 480rpx; background: rgba(15,20,35,0.95); backdrop-filter: blur(20rpx); border: 2rpx solid rgba(99,102,241,0.4); border-radius: 24rpx; box-shadow: 0 12rpx 48rpx rgba(0,0,0,0.6); display: flex; flex-direction: column; z-index: 50; }
.preview-header { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 20rpx; border-bottom: 2rpx solid rgba(255,255,255,0.1); }
.preview-title { font-size: 24rpx; color: rgba(255,255,255,0.8); font-weight: 600; }
.copy-md-btn { padding: 6rpx 16rpx; background: rgba(99,102,241,0.2); border: 1rpx solid rgba(99,102,241,0.4); border-radius: 8rpx; font-size: 20rpx; color: #fff; }
.preview-md-scroll { max-height: 400rpx; padding: 16rpx 20rpx; }
.preview-md { font-size: 22rpx; color: rgba(255,255,255,0.85); line-height: 1.6; white-space: pre-wrap; font-family: monospace; }

/* R118 T2: 雷达图 */
.feed-radar { position: fixed; left: 24rpx; bottom: 160rpx; width: 320rpx; background: rgba(15,20,35,0.85); backdrop-filter: blur(20rpx); border: 2rpx solid rgba(99,102,241,0.3); border-radius: 24rpx; padding: 16rpx; z-index: 50; }
.radar-title { display: block; font-size: 22rpx; color: rgba(255,255,255,0.8); font-weight: 600; margin-bottom: 8rpx; text-align: center; }
.radar-canvas { width: 100%; height: 240rpx; }
.radar-labels { display: flex; justify-content: space-around; margin-top: 8rpx; }
.radar-axis-label { font-size: 18rpx; color: rgba(255,255,255,0.7); }

/* ─── 弹窗 (R99+R114+R115 保留) ───────────────────────── */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.7);
  backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  animation: fadeIn 0.2s ease;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
.modal-card {
  width: 80%;
  max-width: 600rpx;
  background: linear-gradient(180deg, #1a1f2e 0%, #0f1420 100%);
  border-radius: 24rpx;
  padding: 40rpx 36rpx;
  border: 2rpx solid rgba(7,193,96,0.3);
  box-shadow: 0 12rpx 48rpx rgba(0,0,0,0.5), 0 0 32rpx rgba(7,193,96,0.15);
}
.modal-label {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 24rpx;
}
.modal-input {
  width: 100%;
  min-height: 88rpx;
  padding: 24rpx 28rpx;
  font-size: 32rpx;
  background: rgba(255,255,255,0.06);
  border: 2rpx solid rgba(255,255,255,0.1);
  border-radius: 16rpx;
  color: #fff;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}
.modal-input:focus {
  border-color: #07c160;
  background: rgba(7,193,96,0.06);
}
.modal-chips {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}
.modal-chip {
  padding: 20rpx 32rpx;
  background: rgba(255,255,255,0.06);
  border: 2rpx solid rgba(255,255,255,0.1);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #fff;
}
.modal-chip.active {
  background: rgba(7,193,96,0.2);
  border-color: #07c160;
  color: #07c160;
  font-weight: 600;
}
.modal-actions {
  display: flex;
  gap: 16rpx;
}
.modal-cancel {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  background: rgba(255,255,255,0.06);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
}
.modal-save {
  flex: 2;
  padding: 24rpx;
  text-align: center;
  background: linear-gradient(135deg, #07c160 0%, #00a854 100%);
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(7,193,96,0.3);
}

/* ─── AI 多轮对话 (R114 T2) ───────────────────────── */
.ai-chat-history {
  max-height: 240rpx;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: rgba(255,255,255,0.02);
  border-radius: 16rpx;
}
.ai-msg {
  display: flex;
  margin-bottom: 12rpx;
  gap: 12rpx;
}
.ai-msg--user {
  flex-direction: row-reverse;
}
.ai-msg-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
  flex-shrink: 0;
}
.ai-msg-text {
  max-width: 75%;
  padding: 12rpx 16rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 12rpx;
  color: rgba(255,255,255,0.9);
  font-size: 26rpx;
  line-height: 1.4;
}
.ai-msg--user .ai-msg-text {
  background: rgba(7,193,96,0.15);
  color: #07c160;
}
.ai-followup {
  padding: 12rpx 16rpx;
  margin-bottom: 16rpx;
  background: rgba(99,102,241,0.08);
  border-left: 6rpx solid;
  border-radius: 8rpx;
}
.ai-followup-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.4;
}
.ai-suggestion-chip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, rgba(99,102,241,0.15) 0%, rgba(139,92,246,0.15) 100%);
  border: 2rpx solid rgba(99,102,241,0.4);
  border-radius: 16rpx;
}
.ai-suggestion-icon {
  font-size: 28rpx;
}
.ai-suggestion-text {
  flex: 1;
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  line-height: 1.4;
}
.ai-error {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 16rpx;
  background: rgba(220,38,38,0.12);
  border: 2rpx solid rgba(220,38,38,0.4);
  border-radius: 12rpx;
}
.ai-error-text {
  flex: 1;
  font-size: 24rpx;
  color: #fca5a5;
  line-height: 1.4;
}
.ai-error-retry {
  padding: 8rpx 20rpx;
  background: rgba(220,38,38,0.25);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #fff;
}

/* ─── Wizard (R115 模式) ───────────────────────── */
.wizard-progress {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 24rpx;
}
.wizard-progress-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  text-align: right;
}
.wizard-progress-bar {
  height: 8rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 4rpx;
  overflow: hidden;
}
.wizard-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #6366f1 0%, #8b5cf6 100%);
  transition: width 300ms ease;
}
.wizard-question {
  padding: 24rpx;
  margin-bottom: 24rpx;
  background: rgba(99,102,241,0.08);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.wizard-question-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  font-weight: 600;
}
.wizard-question-text {
  font-size: 30rpx;
  color: #fff;
  line-height: 1.5;
  font-weight: 500;
}
.wizard-hint {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  font-style: italic;
}
.wizard-next-btn {
  margin-top: 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 16rpx;
  text-align: center;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}
.wizard-cancel-btn {
  margin-top: 16rpx;
  padding: 16rpx;
  text-align: center;
  color: rgba(255,255,255,0.5);
  font-size: 26rpx;
}

/* R117: Tinder 卡片 */
.tinder-card {
  margin: 24rpx 0;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, rgba(99,102,241,0.18) 0%, rgba(139,92,246,0.18) 100%);
  border: 4rpx solid rgba(99,102,241,0.5);
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(99,102,241,0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  min-height: 240rpx;
  justify-content: center;
}
.tinder-card-counter {
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
}
.tinder-card-reason {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  text-align: center;
}
.tinder-card-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
  line-height: 1.3;
}
.tinder-actions {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin: 16rpx 0;
}
.tinder-btn {
  flex: 1;
  padding: 24rpx 8rpx;
  text-align: center;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  border: 2rpx solid rgba(255,255,255,0.1);
}
.tinder-btn--left {
  background: rgba(220,38,38,0.15);
  border-color: rgba(220,38,38,0.4);
}
.tinder-btn--right {
  background: rgba(7,193,96,0.2);
  border-color: rgba(7,193,96,0.5);
}
.tinder-btn--up {
  background: rgba(251,191,36,0.15);
  border-color: rgba(251,191,36,0.4);
}
.tinder-question {
  padding: 16rpx;
  margin: 16rpx 0;
  text-align: center;
}
.tinder-question-text {
  font-size: 30rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 500;
  line-height: 1.4;
}
.tinder-hint {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 8rpx;
}
.tinder-input {
  margin: 16rpx 0;
}
.tinder-next-btn {
  margin-top: 16rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 16rpx;
  text-align: center;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
}

/* R120: AI 头像脉动 (subtle, 1↔1.02 弱化) */
@keyframes avatar-breathe {
  0%, 100% { transform: scale(1); opacity: 0.7; }
  50% { transform: scale(1.02); opacity: 0.85; }
}
.feed-ai-avatar { animation: avatar-breathe 3s ease-in-out infinite; }

/* R119 A3: 进度条增长 ease-out */
.feed-progress-bar .feed-progress-fill { transition: width 600ms ease-out; }
.feed-progress-num { transition: color 300ms ease; }

/* R119 A5: 完成度爆花 */
@keyframes explode-particle {
  0% { transform: translate(0, 0) scale(0); opacity: 1; }
  100% { transform: translate(var(--dx), var(--dy)) scale(1); opacity: 0; }
}
.explode-overlay { position: fixed; top: 50%; left: 50%; width: 100vw; height: 100vh; transform: translate(-50%, -50%); pointer-events: none; z-index: 100; }
.explode-particle { position: absolute; top: 50%; left: 50%; width: 16rpx; height: 16rpx; border-radius: 50%; background: #fbbf24; animation: explode-particle 1.2s ease-out forwards; box-shadow: 0 0 12rpx #fbbf24; }

/* R120: 100% 时 AI 头像放大闪烁 (subtle) */
@keyframes avatar-celebrate {
  0%, 100% { transform: scale(1); opacity: 0.7; }
  50% { transform: scale(1.15) rotate(8deg); box-shadow: 0 0 40rpx #fbbf24; opacity: 1; }
}
.feed-ai-avatar.celebrate { animation: avatar-celebrate 0.8s ease-in-out infinite; }

/* R119 B2: 进度提示动态 */
.progress-prompt {
  margin: 16rpx 0;
  padding: 16rpx 24rpx;
  background: rgba(99,102,241,0.15);
  border-left: 6rpx solid #6366f1;
  border-radius: 8rpx;
  text-align: center;
}
.progress-prompt-text { font-size: 28rpx; color: rgba(255,255,255,0.9); font-weight: 500; }
.progress-prompt-hint { display: block; font-size: 22rpx; color: rgba(255,255,255,0.5); margin-top: 4rpx; }

/* R119 B4: 完成感弹窗 */
.complete-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(10rpx); display: flex; align-items: center; justify-content: center; z-index: 200; }
.complete-card { background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%); border-radius: 32rpx; padding: 64rpx 48rpx; text-align: center; max-width: 80%; }
.complete-emoji { font-size: 96rpx; display: block; margin-bottom: 16rpx; }
.complete-title { font-size: 48rpx; font-weight: 700; color: #fff; display: block; margin-bottom: 16rpx; }
.complete-subtitle { font-size: 28rpx; color: rgba(255,255,255,0.85); display: block; margin-bottom: 32rpx; }
.complete-btn { padding: 24rpx 48rpx; background: #fff; color: #6366f1; border-radius: 24rpx; font-size: 32rpx; font-weight: 600; display: inline-block; }
