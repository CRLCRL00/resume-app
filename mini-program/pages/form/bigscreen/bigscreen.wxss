/* R98 粒子星图 — 深空背景 + 发光粒子 */

.starfield {
  background: radial-gradient(ellipse at center, #0a0e1a 0%, #050810 70%, #020308 100%);
  position: relative;
  overflow: hidden;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
}

/* ─── 背景小星点 (装饰) ───────────────────────── */
.bg-star {
  position: absolute;
  background: #fff;
  border-radius: 50%;
  box-shadow: 0 0 4rpx #fff;
}

/* ─── 顶部 header ───────────────────────── */
.space-header {
  position: absolute;
  top: 0; left: 0; right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 40rpx;
  z-index: 10;
}
.sh-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.sh-icon {
  font-size: 48rpx;
}
.sh-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
}
.sh-sub {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 2rpx;
}
.sh-close {
  width: 64rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  backdrop-filter: blur(10rpx);
}

/* ─── 中心节点 (完成度) ───────────────────────── */
.center-node {
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 5;
}
.center-pulse {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(99,102,241,0.4) 0%, transparent 70%);
  animation: pulse 3s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { transform: scale(0.8); opacity: 0.5; }
  50% { transform: scale(1.2); opacity: 1; }
}
.center-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(7,193,96,0.3) 0%, rgba(7,193,96,0.1) 100%);
  border: 4rpx solid rgba(7,193,96,0.6);
  display: flex;
  align-items: baseline;
  justify-content: center;
  font-weight: 800;
  color: #fff;
  backdrop-filter: blur(20rpx);
  box-shadow: 0 0 40rpx rgba(7,193,96,0.4);
}
.center-circle.complete {
  background: radial-gradient(circle, rgba(255,140,0,0.5) 0%, rgba(255,140,0,0.2) 100%);
  border-color: rgba(255,140,0,0.8);
  box-shadow: 0 0 60rpx rgba(255,140,0,0.6);
  animation: shake 0.5s ease-in-out infinite;
}
@keyframes shake {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}
.center-num {
  font-size: 56rpx;
  line-height: 1;
}
.center-pct {
  font-size: 28rpx;
  margin-left: 4rpx;
  opacity: 0.7;
}
.center-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 12rpx;
  letter-spacing: 1rpx;
}

/* ─── 星座晕圈 ───────────────────────── */
.const-label {
  position: absolute;
  width: 100rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  opacity: 0.85;
  text-shadow: 0 0 12rpx currentColor;
  z-index: 3;
}
.const-name {
  display: block;
}
.const-halo {
  position: absolute;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 2rpx dashed;
  opacity: 0.4;
  animation: spin 20s linear infinite;
  z-index: 1;
}
@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ─── 粒子 (字段) ───────────────────────── */
.particle {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  cursor: pointer;
  z-index: 4;
}
.particle-glow {
  position: absolute;
  inset: -20rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(var(--pcrgb), 0.3) 0%, transparent 70%);
  opacity: 0.5;
  transition: all 0.3s ease;
}
.particle-core {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: radial-gradient(circle, var(--pc) 0%, rgba(var(--pcrgb), 0.6) 100%);
  border: 2rpx solid var(--pc);
  box-shadow: 0 0 16rpx var(--pc), inset 0 0 12rpx rgba(255,255,255,0.5);
  animation: twinkle 4s ease-in-out infinite;
}
@keyframes twinkle {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.15); opacity: 0.7; }
}
.particle.filled .particle-core {
  background: radial-gradient(circle, #fff 0%, var(--pc) 60%);
  box-shadow: 0 0 32rpx var(--pc), 0 0 64rpx var(--pc);
  animation-duration: 2s;
}
.particle-label {
  position: absolute;
  top: 70rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 20rpx;
  color: rgba(255,255,255,0.85);
  white-space: nowrap;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.8);
  letter-spacing: 1rpx;
}
.particle.filled .particle-label {
  color: var(--pc);
  font-weight: 600;
}
.particle:active .particle-glow {
  opacity: 1;
  transform: scale(1.5);
}
.particle:active .particle-core {
  transform: scale(0.9);
}

/* ─── 浮动预览 ───────────────────────── */
.floating-preview {
  position: absolute;
  bottom: 32rpx;
  right: 32rpx;
  width: 360rpx;
  padding: 24rpx 28rpx;
  background: rgba(15,20,35,0.85);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  border: 2rpx solid rgba(7,193,96,0.3);
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.4);
  z-index: 6;
  animation: slideIn 0.6s ease-out;
}
@keyframes slideIn {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}
.fp-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.1);
  margin-bottom: 12rpx;
}
.fp-title {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  letter-spacing: 2rpx;
}
.fp-completion {
  font-size: 32rpx;
  font-weight: 800;
  color: #07c160;
}
.fp-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 4rpx;
}
.fp-meta {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  margin-bottom: 12rpx;
}
.fp-line {
  display: block;
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  margin-bottom: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ─── 弹窗 ───────────────────────── */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7);
  backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  animation: fadeIn 0.2s ease;
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
.modal-card {
  width: 80%;
  max-width: 600rpx;
  background: linear-gradient(180deg, #1a1f2e 0%, #0f1420 100%);
  border-radius: 24rpx;
  padding: 40rpx 36rpx;
  border: 2rpx solid rgba(7,193,96,0.3);
  box-shadow: 0 12rpx 48rpx rgba(0,0,0,0.5), 0 0 32rpx rgba(7,193,96,0.15);
}

/* R99: AI 提示气泡 (弹窗顶部) */
.modal-ai-bubble {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 16rpx;
  border-left: 6rpx solid;
  align-items: flex-start;
}
.modal-ai-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #fff;
  flex-shrink: 0;
  box-shadow: 0 0 12rpx currentColor;
}
.modal-ai-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.modal-ai-name {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  letter-spacing: 1rpx;
}
.modal-ai-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.95);
  line-height: 1.4;
}

.modal-title {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}
.modal-label {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 24rpx;
}
.modal-input {
  width: 100%;
  min-height: 88rpx;
  padding: 24rpx 28rpx;
  font-size: 32rpx;
  background: rgba(255,255,255,0.06);
  border: 2rpx solid rgba(255,255,255,0.1);
  border-radius: 16rpx;
  color: #fff;
  box-sizing: border-box;
  margin-bottom: 24rpx;
}
.modal-input:focus {
  border-color: #07c160;
  background: rgba(7,193,96,0.06);
}
.modal-chips {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}
.modal-chip {
  padding: 20rpx 32rpx;
  background: rgba(255,255,255,0.06);
  border: 2rpx solid rgba(255,255,255,0.1);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #fff;
}
.modal-chip.active {
  background: rgba(7,193,96,0.2);
  border-color: #07c160;
  color: #07c160;
  font-weight: 600;
}
.modal-picker {
  padding: 28rpx 32rpx;
  background: rgba(255,255,255,0.06);
  border: 2rpx solid rgba(255,255,255,0.1);
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #fff;
  text-align: center;
  margin-bottom: 24rpx;
}
.modal-actions {
  display: flex;
  gap: 16rpx;
}
.modal-cancel {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  background: rgba(255,255,255,0.06);
  border-radius: 16rpx;
  font-size: 28rpx;
  color: rgba(255,255,255,0.7);
}
.modal-save {
  flex: 2;
  padding: 24rpx;
  text-align: center;
  background: linear-gradient(135deg, #07c160 0%, #00a854 100%);
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(7,193,96,0.3);
}