<!--
  R96 大屏填简历 — 精致版
  Hero (绿渐变) + 步骤指示器 (浮在 hero 下方) + 左输入 + 右预览卡片
  浮动 label 输入 (focus 时 label 浮起)
-->
<view class="bigscreen {{wide ? 'wide' : 'narrow'}}">

  <!-- Hero 区: 品牌渐变 + 大标题 -->
  <view class="hero">
    <view class="hero-close" bindtap="goBack">✕</view>
    <view class="hero-icon">✍️</view>
    <view class="hero-title">智能简历助手</view>
    <view class="hero-sub">5 步填完, 自动生成专业简历</view>
  </view>

  <!-- 步骤指示器 (浮在 hero 下方) -->
  <view class="stepper">
    <view class="stepper-item {{step > index ? 'done' : ''}} {{step === index ? 'active' : ''}}"
          wx:for="{{stepLabels}}" wx:key="index"
          data-index="{{index}}"
          bindtap="goStep">
      <view class="stepper-circle">{{step > index ? '✓' : (index + 1)}}</view>
      <text class="stepper-name">{{item}}</text>
    </view>
  </view>

  <!-- 主区: 左输入 + 右预览 -->
  <view class="main">
    <!-- 左侧: 当前步骤输入 -->
    <scroll-view class="left-pane" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="step-header">
        <view class="step-num-badge">第 {{step + 1}} / {{stepLabels.length}} 步</view>
        <text class="step-title">{{stepLabels[step]}}</text>
        <text class="step-hint">{{stepHints[step]}}</text>
      </view>

      <!-- Step 0: 基本信息 -->
      <block wx:if="{{step === 0}}">
        <view class="field-float {{form.name ? 'has-value' : ''}}">
          <input class="field-float-input"
                 placeholder=" "
                 value="{{form.name}}"
                 bindinput="setField"
                 data-field="name" />
          <text class="field-float-label">姓名</text>
        </view>
        <view class="field-float-label" style="position:static;font-size:28rpx;margin-bottom:16rpx;">性别</view>
        <view class="chips">
          <view class="chip {{form.gender === 'male' ? 'chip-active' : ''}}"
                data-value="male" bindtap="setGender">男</view>
          <view class="chip {{form.gender === 'female' ? 'chip-active' : ''}}"
                data-value="female" bindtap="setGender">女</view>
          <view class="chip {{form.gender === 'other' ? 'chip-active' : ''}}"
                data-value="other" bindtap="setGender">其他</view>
        </view>
        <view class="field-float {{form.degree ? 'has-value' : ''}}">
          <picker mode="selector" range="{{degreeOptions}}" value="{{degreeIndex}}" bindchange="setDegree">
            <view class="field-float-input picker">{{degreeOptions[degreeIndex] || ''}}</view>
          </picker>
          <text class="field-float-label">学历</text>
        </view>
        <view class="field-float {{form.phone ? 'has-value' : ''}}">
          <input class="field-float-input"
                 placeholder=" "
                 type="number"
                 value="{{form.phone}}"
                 bindinput="setField"
                 data-field="phone" />
          <text class="field-float-label">手机（可选）</text>
        </view>
      </block>

      <!-- Step 1: 教育经历 -->
      <block wx:if="{{step === 1}}">
        <view class="repeat-card" wx:for="{{form.educations}}" wx:key="eidx" wx:for-item="edu" wx:for-index="eidx">
          <view class="repeat-header">
            <text class="repeat-title">教育 {{eidx + 1}}</text>
            <view class="btn-link" bindtap="removeEdu" data-index="{{eidx}}" wx:if="{{form.educations.length > 1}}">删除</view>
          </view>
          <view class="field-float {{edu.school ? 'has-value' : ''}}">
            <input class="field-float-input" placeholder=" " value="{{edu.school}}"
                   bindinput="setEdu" data-index="{{eidx}}" data-field="school" />
            <text class="field-float-label">学校</text>
          </view>
          <view class="field-float {{edu.major ? 'has-value' : ''}}">
            <input class="field-float-input" placeholder=" " value="{{edu.major}}"
                   bindinput="setEdu" data-index="{{eidx}}" data-field="major" />
            <text class="field-float-label">专业</text>
          </view>
          <view class="field-float" style="margin-bottom:0;">
            <text class="field-float-label">起止时间</text>
          </view>
          <view class="date-row" style="margin-top:-16rpx;">
            <input class="field-float-input date-input" placeholder="2020-09" value="{{edu.start}}"
                   bindinput="setEdu" data-index="{{eidx}}" data-field="start" />
            <text class="date-sep">至</text>
            <input class="field-float-input date-input" placeholder="2024-06 或 至今" value="{{edu.end}}"
                   bindinput="setEdu" data-index="{{eidx}}" data-field="end" />
          </view>
        </view>
        <view class="btn-add" bindtap="addEdu">+ 添加教育经历</view>
      </block>

      <!-- Step 2: 工作经历 -->
      <block wx:if="{{step === 2}}">
        <view class="repeat-card" wx:for="{{form.experiences}}" wx:key="xidx" wx:for-item="exp" wx:for-index="xidx">
          <view class="repeat-header">
            <text class="repeat-title">工作 {{xidx + 1}}</text>
            <view class="btn-link" bindtap="removeExp" data-index="{{xidx}}" wx:if="{{form.experiences.length > 1}}">删除</view>
          </view>
          <view class="field-float {{exp.company ? 'has-value' : ''}}">
            <input class="field-float-input" placeholder=" " value="{{exp.company}}"
                   bindinput="setExp" data-index="{{xidx}}" data-field="company" />
            <text class="field-float-label">公司</text>
          </view>
          <view class="field-float {{exp.title ? 'has-value' : ''}}">
            <input class="field-float-input" placeholder=" " value="{{exp.title}}"
                   bindinput="setExp" data-index="{{xidx}}" data-field="title" />
            <text class="field-float-label">职位</text>
          </view>
          <view class="field-float" style="margin-bottom:0;">
            <text class="field-float-label">起止时间</text>
          </view>
          <view class="date-row" style="margin-top:-16rpx;">
            <input class="field-float-input date-input" placeholder="2021-07" value="{{exp.start}}"
                   bindinput="setExp" data-index="{{xidx}}" data-field="start" />
            <text class="date-sep">至</text>
            <input class="field-float-input date-input" placeholder="至今" value="{{exp.end}}"
                   bindinput="setExp" data-index="{{xidx}}" data-field="end" />
          </view>
          <view class="field-float {{exp.desc ? 'has-value' : ''}}">
            <textarea class="field-float-input textarea-big" placeholder=" " value="{{exp.desc}}"
                      bindinput="setExp" data-index="{{xidx}}" data-field="desc" />
            <text class="field-float-label">工作描述</text>
          </view>
        </view>
        <view class="btn-add" bindtap="addExp">+ 添加工作经历</view>
      </block>

      <!-- Step 3: 求职期望 -->
      <block wx:if="{{step === 3}}">
        <view class="field-float {{form.expected.city ? 'has-value' : ''}}">
          <input class="field-float-input" placeholder=" " value="{{form.expected.city}}"
                 bindinput="setExpected" data-field="city" />
          <text class="field-float-label">期望城市</text>
        </view>
        <view class="field-float {{form.expected.position ? 'has-value' : ''}}">
          <input class="field-float-input" placeholder=" " value="{{form.expected.position}}"
                 bindinput="setExpected" data-field="position" />
          <text class="field-float-label">期望岗位</text>
        </view>
        <view class="field-float" style="margin-bottom:0;">
          <text class="field-float-label">期望薪资（K）</text>
        </view>
        <view class="date-row" style="margin-top:-16rpx;">
          <input class="field-float-input date-input" type="number" placeholder="下限" value="{{form.expected.salary_min}}"
                 bindinput="setExpected" data-field="salary_min" />
          <text class="date-sep">—</text>
          <input class="field-float-input date-input" type="number" placeholder="上限" value="{{form.expected.salary_max}}"
                 bindinput="setExpected" data-field="salary_max" />
        </view>
      </block>

      <!-- Step 4: 技能 -->
      <block wx:if="{{step === 4}}">
        <view class="field-float {{skillsInput ? 'has-value' : ''}}">
          <textarea class="field-float-input textarea-big" placeholder=" " value="{{skillsInput}}"
                    bindinput="setSkillsInput" />
          <text class="field-float-label">技能 (逗号分隔)</text>
        </view>
        <text class="field-hint">已识别 {{skillsCount}} 项技能</text>
      </block>

      <!-- 步骤切换 -->
      <view class="step-nav">
        <view class="btn-secondary" bindtap="prevStep" wx:if="{{step > 0}}">← 上一步</view>
        <view class="btn-primary" bindtap="nextStep" wx:if="{{step < stepLabels.length - 1}}">下一步 →</view>
        <view class="btn-primary submit" bindtap="submit" wx:if="{{step === stepLabels.length - 1}}">生成简历 ✨</view>
      </view>
    </scroll-view>

    <!-- 右侧: 简历预览卡片 -->
    <view class="right-pane" wx:if="{{wide}}">
      <view class="preview-card">
        <view class="preview-header">
          <text class="preview-name">{{form.name || '未填姓名'}}</text>
          <view class="preview-completion">
            <text class="completion-num">{{completion}}</text>
            <text class="completion-pct">%</text>
          </view>
        </view>
        <view class="preview-meta">
          <text wx:if="{{form.gender}}">{{form.gender === 'male' ? '男' : form.gender === 'female' ? '女' : '其他'}}</text>
          <text wx:if="{{form.degree}}">{{form.degree}}</text>
          <text wx:if="{{form.phone}}">{{form.phone}}</text>
        </view>

        <view class="preview-section" wx:if="{{form.expected.city || form.expected.position}}">
          <view class="preview-section-title">求职期望</view>
          <text class="preview-line">{{form.expected.position || '岗位待定'}} · {{form.expected.city || '城市待定'}}</text>
          <text class="preview-line" wx:if="{{form.expected.salary_min || form.expected.salary_max}}">
            薪资 {{form.expected.salary_min || '?'}}-{{form.expected.salary_max || '?'}}K
          </text>
        </view>

        <view class="preview-section" wx:if="{{form.educations.length && form.educations[0].school}}">
          <view class="preview-section-title">教育</view>
          <view wx:for="{{form.educations}}" wx:key="eidx" wx:for-item="edu" wx:for-index="eidx" wx:if="{{edu.school}}">
            <text class="preview-line">{{edu.school}} · {{edu.major || '专业'}}</text>
            <text class="preview-line-mini">{{edu.start || '?'}} - {{edu.end || '?'}}</text>
          </view>
        </view>

        <view class="preview-section" wx:if="{{form.experiences.length && form.experiences[0].company}}">
          <view class="preview-section-title">工作</view>
          <view wx:for="{{form.experiences}}" wx:key="xidx" wx:for-item="exp" wx:for-index="xidx" wx:if="{{exp.company}}">
            <text class="preview-line">{{exp.company}} · {{exp.title || '职位'}}</text>
            <text class="preview-line-mini">{{exp.start || '?'}} - {{exp.end || '?'}}</text>
            <text class="preview-line-mini" wx:if="{{exp.desc}}">{{exp.desc}}</text>
          </view>
        </view>

        <view class="preview-section" wx:if="{{skillsCount > 0}}">
          <view class="preview-section-title">技能</view>
          <text class="preview-line">{{form.skills.join(' · ')}}</text>
        </view>
      </view>
    </view>
  </view>

</view>