<!--
  R116 抖音式大屏 — 砍掉 R98 星图, 改竖滑 feed
  5 星座纵向切换 + 字段卡片横滑 + AI 头像大字
  R115 wizard + 后端 deepseek 仍工作 (modal 部分保留)

  R109/R113 教训: 所有 opening tag 必须单行 (attribute 不跨行)
-->
<view class="feed-page">

  <scroll-view class="feed-scroll" scroll-y="true" bindscrolltolower="onFeedScrollLower">

    <!-- 顶部进度点 (5 星座 × 进度数字) -->
    <view class="feed-progress">
      <view wx:for="{{sections}}" wx:key="id" wx:for-item="sec" wx:for-index="idx" class="feed-dot {{currentSection === idx ? 'active' : ''}} {{idx < currentSection ? 'done' : ''}}" data-section-idx="{{idx}}"></view>
      <text class="feed-progress-num">{{currentFieldIndex}} / {{wizardTotal}}</text>
    </view>

    <!-- 5 星座 section (竖排, 每屏 1 个) -->
    <view wx:for="{{sections}}" wx:key="id" wx:for-item="section" wx:for-index="idx" class="feed-section feed-section--{{section.id}}" data-section-id="{{section.id}}">
      <!-- AI 头像 -->
      <view class="feed-ai-avatar">✨</view>
      <!-- 星座名大字 -->
      <text class="feed-section-name">{{section.name}}</text>
      <!-- 字段卡片 (横滑) -->
      <scroll-view class="feed-fields" scroll-x="true">
        <view wx:for="{{section.fields}}" wx:key="id" wx:for-item="field" wx:for-index="fIdx" class="feed-field-card {{_isFieldFilled(field.id) ? 'filled' : ''}} {{currentFieldId === field.id ? 'current' : ''}} {{_getFieldIndex(field.id) < currentFieldIndex ? 'done' : ''}}" data-field-id="{{field.id}}" data-section-idx="{{idx}}" bindtap="onFieldCardTap">
          <text class="feed-field-label">{{field.label}}</text>
          <text wx:if="{{_isFieldFilled(field.id)}}" class="feed-field-value">{{_getFieldValue(field.id)}}</text>
          <text wx:elif="{{currentFieldId === field.id}}" class="feed-field-prompt">?</text>
        </view>
      </scroll-view>
    </view>

    <!-- 滑到底部提示 -->
    <view class="feed-footer">
      <text class="feed-footer-text">↑ 下滑下一星座</text>
    </view>
  </scroll-view>

  <!-- 底部 fixed 大输入框 (R116 T4: 接 AI wizard) -->
  <view class="feed-input-bar">
    <input class="feed-input" placeholder="{{currentFieldPrompt || '点击上方字段开始'}}" value="{{modalValue}}" bindinput="onModalInput" focus="{{false}}" bindconfirm="onModalSave" />
    <view class="feed-send-btn" bindtap="onModalSave">发送</view>
  </view>

  <!-- R99+R114 弹窗 (wizard 模式用, 保留兼容) -->
  <view class="modal-mask" wx:if="{{modalVisible}}" bindtap="onModalCancel">
    <view class="modal-card" catchtap="">
      <block wx:if="{{wizardMode}}">
        <view class="wizard-progress">
          <text class="wizard-progress-text">{{wizardProgress}} / {{wizardTotal}}</text>
          <view class="wizard-progress-bar">
            <view class="wizard-progress-fill" style="width: {{(wizardProgress / wizardTotal) * 100}}%;"></view>
          </view>
        </view>
        <view class="wizard-question">
          <text class="wizard-question-label">✨ 简历助手</text>
          <text class="wizard-question-text">{{wizardNextQuestion || '...'}}</text>
          <text wx:if="{{wizardHint}}" class="wizard-hint">{{wizardHint}}</text>
        </view>
        <block wx:if="{{!modalOptions}}">
          <input class="modal-input" placeholder="{{modalPlaceholder}}" value="{{modalValue}}" bindinput="onModalInput" focus="{{true}}" bindconfirm="onModalSave" />
        </block>
        <block wx:if="{{modalOptions && modalOptions[0].label}}">
          <view class="modal-chips">
            <view class="modal-chip {{modalValue === item.value ? 'active' : ''}}" wx:for="{{modalOptions}}" wx:key="value" data-value="{{item.value}}" bindtap="onModalChip">{{item.label}}</view>
          </view>
        </block>
        <view class="wizard-next-btn" bindtap="onModalSave">下一问 →</view>
        <view class="wizard-cancel-btn" bindtap="onModalCancel">取消</view>
      </block>
      <block wx:else>
        <scroll-view class="ai-chat-history" scroll-y="true" scroll-top="{{aiScrollTop}}" wx:if="{{aiHistory.length > 0}}">
          <view wx:for="{{aiHistory}}" wx:key="id" wx:for-item="msg" class="ai-msg ai-msg--{{msg.role}}">
            <view wx:if="{{msg.role === 'assistant'}}" class="ai-msg-avatar" style="background: {{modalConstColor}};">✨</view>
            <view class="ai-msg-text">{{msg.content}}</view>
          </view>
        </scroll-view>
        <view class="ai-followup" wx:if="{{aiFollowup}}" style="border-left-color: {{modalConstColor}};">
          <text class="ai-followup-text">{{aiFollowup}}</text>
        </view>
        <view class="ai-suggestion-chip" wx:if="{{aiSuggestion}}" bindtap="onAISuggestionTap">
          <text class="ai-suggestion-icon">💡</text>
          <text class="ai-suggestion-text">{{aiSuggestion}}</text>
        </view>
        <view class="ai-error" wx:if="{{aiError}}">
          <text class="ai-error-text">⚠️ {{aiError}}</text>
          <view class="ai-error-retry" bindtap="onAIErrorRetry">重试</view>
        </view>
        <text class="modal-label">{{modalFieldLabel}}</text>
        <block wx:if="{{!modalOptions}}">
          <input class="modal-input" placeholder="{{modalPlaceholder}}" value="{{modalValue}}" bindinput="onModalInput" focus="{{true}}" bindconfirm="onModalSave" />
        </block>
        <view class="modal-actions">
          <view class="modal-cancel" bindtap="onModalCancel">取消</view>
          <view class="modal-save" bindtap="onModalSave">保存 ✨</view>
        </view>
      </block>
    </view>
  </view>

</view>
