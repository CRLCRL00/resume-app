<!--
  R94 大屏填简历 — 5 步分步 + 左输入右预览
  入口: form.wxml 顶部 "🖥 大屏模式" 按钮
  自适应: windowWidth ≥ 1024 → 大屏两栏; 否则单栏堆叠
-->
<view class="bigscreen {{wide ? 'wide' : 'narrow'}}">

  <!-- 顶部: 标题 + 关闭 -->
  <view class="topbar">
    <view class="topbar-title">简历助手 · 大屏模式</view>
    <view class="topbar-close" bindtap="goBack">✕</view>
  </view>

  <!-- 进度条 -->
  <view class="progress">
    <view class="step-dot {{step >= index ? 'active' : ''}}"
          wx:for="{{stepLabels}}" wx:key="index"
          data-index="{{index}}"
          bindtap="goStep">
      <text class="step-num">{{index + 1}}</text>
      <text class="step-name">{{item}}</text>
    </view>
  </view>

  <!-- 主区: 左输入 + 右预览 -->
  <view class="main">
    <!-- 左侧: 当前步骤输入 -->
    <scroll-view class="left-pane" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="step-header">
        <text class="step-title">{{stepLabels[step]}}</text>
        <text class="step-hint">{{stepHints[step]}}</text>
      </view>

      <!-- Step 0: 基本信息 -->
      <block wx:if="{{step === 0}}">
        <view class="field-big">
          <text class="field-label">姓名</text>
          <input class="field-input"
                 placeholder="请输入姓名"
                 value="{{form.name}}"
                 bindinput="setField"
                 data-field="name"
                 focus="{{step === 0 && focusIndex === 0}}" />
        </view>
        <view class="field-big">
          <text class="field-label">性别</text>
          <view class="gender-row">
            <view class="chip {{form.gender === 'male' ? 'chip-active' : ''}}"
                  data-value="male" bindtap="setGender">男</view>
            <view class="chip {{form.gender === 'female' ? 'chip-active' : ''}}"
                  data-value="female" bindtap="setGender">女</view>
            <view class="chip {{form.gender === 'other' ? 'chip-active' : ''}}"
                  data-value="other" bindtap="setGender">其他</view>
          </view>
        </view>
        <view class="field-big">
          <text class="field-label">学历</text>
          <picker mode="selector" range="{{degreeOptions}}" value="{{degreeIndex}}" bindchange="setDegree">
            <view class="field-input picker">{{degreeOptions[degreeIndex] || '请选择学历'}}</view>
          </picker>
        </view>
        <view class="field-big">
          <text class="field-label">手机（可选）</text>
          <input class="field-input"
                 placeholder="13800000000"
                 type="number"
                 value="{{form.phone}}"
                 bindinput="setField"
                 data-field="phone" />
        </view>
      </block>

      <!-- Step 1: 教育经历 -->
      <block wx:if="{{step === 1}}">
        <view class="repeat-card" wx:for="{{form.educations}}" wx:key="eidx" wx:for-item="edu" wx:for-index="eidx">
          <view class="repeat-header">
            <text class="repeat-title">教育 {{eidx + 1}}</text>
            <view class="btn-link" bindtap="removeEdu" data-index="{{eidx}}" wx:if="{{form.educations.length > 1}}">删除</view>
          </view>
          <view class="field-big">
            <text class="field-label">学校</text>
            <input class="field-input"
                   placeholder="如: 清华大学"
                   value="{{edu.school}}"
                   bindinput="setEdu" data-index="{{eidx}}" data-field="school" />
          </view>
          <view class="field-big">
            <text class="field-label">专业</text>
            <input class="field-input"
                   placeholder="如: 计算机科学"
                   value="{{edu.major}}"
                   bindinput="setEdu" data-index="{{eidx}}" data-field="major" />
          </view>
          <view class="field-big">
            <text class="field-label">起止时间</text>
            <view class="date-row">
              <input class="field-input date-input"
                     placeholder="2020-09"
                     value="{{edu.start}}"
                     bindinput="setEdu" data-index="{{eidx}}" data-field="start" />
              <text class="date-sep">至</text>
              <input class="field-input date-input"
                     placeholder="2024-06 或 至今"
                     value="{{edu.end}}"
                     bindinput="setEdu" data-index="{{eidx}}" data-field="end" />
            </view>
          </view>
        </view>
        <view class="btn-add" bindtap="addEdu">+ 添加教育经历</view>
      </block>

      <!-- Step 2: 工作经历 -->
      <block wx:if="{{step === 2}}">
        <view class="repeat-card" wx:for="{{form.experiences}}" wx:key="xidx" wx:for-item="exp" wx:for-index="xidx">
          <view class="repeat-header">
            <text class="repeat-title">工作 {{xidx + 1}}</text>
            <view class="btn-link" bindtap="removeExp" data-index="{{xidx}}" wx:if="{{form.experiences.length > 1}}">删除</view>
          </view>
          <view class="field-big">
            <text class="field-label">公司</text>
            <input class="field-input"
                   placeholder="如: 阿里巴巴"
                   value="{{exp.company}}"
                   bindinput="setExp" data-index="{{xidx}}" data-field="company" />
          </view>
          <view class="field-big">
            <text class="field-label">职位</text>
            <input class="field-input"
                   placeholder="如: 前端工程师"
                   value="{{exp.title}}"
                   bindinput="setExp" data-index="{{xidx}}" data-field="title" />
          </view>
          <view class="field-big">
            <text class="field-label">起止时间</text>
            <view class="date-row">
              <input class="field-input date-input"
                     placeholder="2021-07"
                     value="{{exp.start}}"
                     bindinput="setExp" data-index="{{xidx}}" data-field="start" />
              <text class="date-sep">至</text>
              <input class="field-input date-input"
                     placeholder="至今"
                     value="{{exp.end}}"
                     bindinput="setExp" data-index="{{xidx}}" data-field="end" />
            </view>
          </view>
          <view class="field-big">
            <text class="field-label">工作描述</text>
            <textarea class="field-input textarea-big"
                      placeholder="简述主要工作内容与成果..."
                      value="{{exp.desc}}"
                      bindinput="setExp" data-index="{{xidx}}" data-field="desc" />
          </view>
        </view>
        <view class="btn-add" bindtap="addExp">+ 添加工作经历</view>
      </block>

      <!-- Step 3: 求职期望 -->
      <block wx:if="{{step === 3}}">
        <view class="field-big">
          <text class="field-label">期望城市</text>
          <input class="field-input"
                 placeholder="如: 深圳"
                 value="{{form.expected.city}}"
                 bindinput="setExpected" data-field="city" />
        </view>
        <view class="field-big">
          <text class="field-label">期望岗位</text>
          <input class="field-input"
                 placeholder="如: 全栈工程师"
                 value="{{form.expected.position}}"
                 bindinput="setExpected" data-field="position" />
        </view>
        <view class="field-big">
          <text class="field-label">期望薪资（K）</text>
          <view class="date-row">
            <input class="field-input date-input"
                   type="number"
                   placeholder="下限"
                   value="{{form.expected.salary_min}}"
                   bindinput="setExpected" data-field="salary_min" />
            <text class="date-sep">—</text>
            <input class="field-input date-input"
                   type="number"
                   placeholder="上限"
                   value="{{form.expected.salary_max}}"
                   bindinput="setExpected" data-field="salary_max" />
          </view>
        </view>
      </block>

      <!-- Step 4: 技能 -->
      <block wx:if="{{step === 4}}">
        <view class="field-big">
          <text class="field-label">技能</text>
          <textarea class="field-input textarea-big"
                    placeholder="用逗号分隔, 如: React, Vue, TypeScript, Node.js"
                    value="{{skillsInput}}"
                    bindinput="setSkillsInput" />
          <text class="field-hint">已识别 {{skillsCount}} 项技能</text>
        </view>
      </block>

      <!-- 步骤切换 -->
      <view class="step-nav">
        <view class="btn-secondary" bindtap="prevStep" wx:if="{{step > 0}}">← 上一步</view>
        <view class="btn-primary" bindtap="nextStep" wx:if="{{step < stepLabels.length - 1}}">下一步 →</view>
        <view class="btn-primary submit" bindtap="submit" wx:if="{{step === stepLabels.length - 1}}">生成简历 ✨</view>
      </view>
    </scroll-view>

    <!-- 右侧: 简历预览卡片 -->
    <view class="right-pane" wx:if="{{wide}}">
      <view class="preview-card">
        <view class="preview-header">
          <text class="preview-name">{{form.name || '未填姓名'}}</text>
          <view class="preview-completion">
            <text class="completion-num">{{completion}}</text>
            <text class="completion-pct">%</text>
          </view>
        </view>
        <view class="preview-meta">
          <text wx:if="{{form.gender}}">{{form.gender === 'male' ? '男' : form.gender === 'female' ? '女' : '其他'}}</text>
          <text wx:if="{{form.degree}}">· {{form.degree}}</text>
          <text wx:if="{{form.phone}}">· {{form.phone}}</text>
        </view>

        <view class="preview-section" wx:if="{{form.expected.city || form.expected.position}}">
          <text class="preview-section-title">求职期望</text>
          <text class="preview-line">{{form.expected.position || '岗位待定'}} · {{form.expected.city || '城市待定'}}</text>
          <text class="preview-line" wx:if="{{form.expected.salary_min || form.expected.salary_max}}">
            薪资 {{form.expected.salary_min || '?'}}-{{form.expected.salary_max || '?'}}K
          </text>
        </view>

        <view class="preview-section" wx:if="{{form.educations.length && form.educations[0].school}}">
          <text class="preview-section-title">教育</text>
          <view wx:for="{{form.educations}}" wx:key="eidx" wx:for-item="edu" wx:for-index="eidx" wx:if="{{edu.school}}">
            <text class="preview-line">{{edu.school}} · {{edu.major || '专业'}}</text>
            <text class="preview-line-mini">{{edu.start || '?'}} - {{edu.end || '?'}}</text>
          </view>
        </view>

        <view class="preview-section" wx:if="{{form.experiences.length && form.experiences[0].company}}">
          <text class="preview-section-title">工作</text>
          <view wx:for="{{form.experiences}}" wx:key="xidx" wx:for-item="exp" wx:for-index="xidx" wx:if="{{exp.company}}">
            <text class="preview-line">{{exp.company}} · {{exp.title || '职位'}}</text>
            <text class="preview-line-mini">{{exp.start || '?'}} - {{exp.end || '?'}}</text>
            <text class="preview-line-mini" wx:if="{{exp.desc}}">{{exp.desc}}</text>
          </view>
        </view>

        <view class="preview-section" wx:if="{{skillsCount > 0}}">
          <text class="preview-section-title">技能</text>
          <text class="preview-line">{{form.skills.join(' · ')}}</text>
        </view>
      </view>
    </view>
  </view>

</view>