.container {
  padding: 40rpx;
}
.title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}
.meta {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 40rpx;
}
.content {
  font-size: 28rpx;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}
.loading, .error {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}
.error button {
  margin-top: 30rpx;
  background: #1aad19;
  color: #fff;
  font-size: 28rpx;
  border-radius: 8rpx;
}