.container {
  padding: 20rpx;
}
.header {
  padding: 40rpx 20rpx;
  text-align: center;
}
.title {
  font-size: 40rpx;
  font-weight: bold;
}
.section {
  background: #fff;
  border-radius: 12rpx;
  margin: 30rpx 0;
  overflow: hidden;
}
.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  font-size: 30rpx;
}
.row:last-child { border-bottom: none; }
.arrow { color: #ccc; font-size: 36rpx; }
.admin-row { background: #f0f7ff; }
.admin-text { color: #1aad19; }
.admin-only { border: 2rpx solid #1aad19; }
