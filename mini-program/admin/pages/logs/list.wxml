<view class="container">
  <view class="empty-wrap" wx:if="{{loading}}">
    <text>加载中…</text>
  </view>
  <view class="empty-wrap" wx:elif="{{items.length === 0}}">
    <text class="empty">{{emptyText || '暂无数据'}}</text>
    <button class="btn-secondary empty-retry" bindtap="loadList">重试</button>
  </view>
  <view wx:for="{{items}}" wx:key="id" class="card">
    <view style="display:flex; justify-content:space-between;">
      <view style="font-weight:bold;">{{item.action}}</view>
      <view class="label">{{item.created_at}}</view>
    </view>
    <view class="label">admin: {{item.admin_openid}}</view>
    <view wx:if="{{item.target_id}}" class="label">target: {{item.target_type}}#{{item.target_id}}</view>
  </view>
</view>
