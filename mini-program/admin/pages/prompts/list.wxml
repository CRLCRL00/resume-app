<view class="container">
  <view class="empty-wrap" wx:if="{{loading}}">
    <text>加载中…</text>
  </view>
  <view class="empty-wrap" wx:elif="{{items.length === 0}}">
    <text class="empty">{{emptyText || '暂无数据'}}</text>
    <button class="btn-secondary empty-retry" bindtap="loadList">重试</button>
  </view>
  <view wx:for="{{items}}" wx:key="code" class="card" bindtap="goEdit" data-code="{{item.code}}">
    <view style="font-weight:bold;">{{item.code}}</view>
    <view class="label">v{{item.version}} · {{item.updated_at}}</view>
  </view>
</view>
