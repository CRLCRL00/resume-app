.dashboard {
  padding: 24rpx;
  background: #0d1424;
  min-height: 100vh;
  color: #e6e9f2;
}

/* R58: fullscreen 大屏模式 - 大字号/大间距/单屏铺满 (1920×1080 电视墙) */
.dashboard--fullscreen {
  padding: 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}
.fs-header {
  display: flex;
  align-items: center;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(92, 182, 255, .25);
  margin-bottom: 24rpx;
}
.fs-title {
  flex: 1;
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 4rpx;
}
.fs-time {
  font-size: 56rpx;
  color: #5cb6ff;
  font-variant-numeric: tabular-nums;
  font-weight: 600;
  margin-right: 32rpx;
  text-shadow: 0 0 24rpx rgba(60, 160, 255, .35);
}
.fs-exit, .cp-toggle {
  font-size: 24rpx;
  color: #5cb6ff;
  border: 1rpx solid rgba(92, 182, 255, .4);
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  background: rgba(20, 28, 48, .55);
}
.fs-exit {
  font-size: 28rpx;
  padding: 12rpx 32rpx;
}
.cp-toggle {
  position: fixed;
  top: 24rpx;
  right: 24rpx;
  z-index: 10;
}

/* R58: fullscreen 内容放大 — 主区用 flex:1 自适应填充 */
.dashboard--fullscreen .kpi-row {
  flex: 0 0 auto;
  margin-bottom: 24rpx;
}
.dashboard--fullscreen .kpi-card {
  padding: 32rpx;
  border-radius: 16rpx;
}
.dashboard--fullscreen .kpi-n {
  font-size: 96rpx;
}
.dashboard--fullscreen .kpi-label {
  font-size: 30rpx;
  margin-top: 8rpx;
}
.dashboard--fullscreen .kpi-delta {
  font-size: 26rpx;
  margin-top: 8rpx;
}
.dashboard--fullscreen .block {
  flex: 1 1 auto;
  padding: 32rpx;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.dashboard--fullscreen .block-title {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}
.dashboard--fullscreen .block-sub {
  font-size: 24rpx;
  margin-bottom: 16rpx;
}
.dashboard--fullscreen .duo {
  gap: 32rpx;
}
.dashboard--fullscreen .duo-head {
  font-size: 28rpx;
  margin-bottom: 12rpx;
}
.dashboard--fullscreen .bar-row {
  font-size: 26rpx;
  margin-bottom: 12rpx;
}
.dashboard--fullscreen .bar-row--wide {
  font-size: 30rpx;
  margin-bottom: 16rpx;
}
.dashboard--fullscreen .bar-label {
  width: 140rpx;
}
.dashboard--fullscreen .bar-track {
  height: 22rpx;
  border-radius: 11rpx;
}
.dashboard--fullscreen .bar-fill {
  border-radius: 11rpx;
}
.dashboard--fullscreen .bar-n {
  width: 100rpx;
  font-size: 28rpx;
  margin-left: 16rpx;
}
.dashboard--fullscreen .trend-wrap {
  max-height: none;
}
.dashboard--fullscreen .trend-row {
  padding: 14rpx 0;
  font-size: 26rpx;
}
.dashboard--fullscreen .trend-date {
  width: 140rpx;
}
.dashboard--fullscreen .trend-cell {
  padding: 6rpx 18rpx;
  font-size: 24rpx;
}

.kpi-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 32rpx;
}
.kpi-card {
  background: linear-gradient(135deg, rgba(47, 109, 246, .18) 0%, rgba(20, 39, 84, .55) 100%);
  border: 1rpx solid rgba(80, 140, 255, .25);
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
}
.kpi-n {
  font-size: 60rpx;
  font-weight: 700;
  color: #5cb6ff;
  text-shadow: 0 0 24rpx rgba(60, 160, 255, .35);
  line-height: 1.1;
}
.kpi-label {
  font-size: 24rpx;
  color: #c4cad8;
  margin-top: 8rpx;
}
.kpi-delta {
  font-size: 22rpx;
  color: #6c7b95;
  margin-top: 6rpx;
}
.block {
  background: rgba(20, 28, 48, .55);
  border: 1rpx solid rgba(255, 255, 255, .08);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.block-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 4rpx;
}
.block-sub {
  font-size: 22rpx;
  color: #8d96ad;
  margin-bottom: 20rpx;
}
.duo {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}
.duo-head {
  font-size: 26rpx;
  color: #5cb6ff;
  margin-bottom: 12rpx;
}
.bar-row {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  margin-bottom: 10rpx;
  white-space: nowrap;
}
.bar-row--wide {
  font-size: 24rpx;
  margin-bottom: 14rpx;
}
.bar-label {
  width: 90rpx;
  color: #c4cad8;
  overflow: hidden;
  text-overflow: ellipsis;
}
.bar-track {
  flex: 1;
  height: 14rpx;
  background: rgba(255, 255, 255, .06);
  border-radius: 7rpx;
  overflow: hidden;
}
.bar-fill {
  height: 100%;
  border-radius: 7rpx;
  transition: width .5s ease;
}
.bar-fill--user { background: linear-gradient(90deg, #5cb6ff, #2d7df7); }
.bar-fill--job  { background: linear-gradient(90deg, #fbb55f, #f7843a); }
.bar-n {
  width: 70rpx;
  text-align: right;
  color: #fff;
  font-weight: 600;
  margin-left: 12rpx;
}
.trend-wrap {
  max-height: 360rpx;
  overflow-y: auto;
}
.trend-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, .04);
  font-size: 22rpx;
}
.trend-date {
  width: 110rpx;
  color: #6c7b95;
}
.trend-bars {
  display: flex;
  gap: 12rpx;
  flex: 1;
}
.trend-cell {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .06);
  color: #e6e9f2;
  font-size: 20rpx;
}
.empty {
  font-size: 22rpx;
  color: #6c7b95;
  text-align: center;
  padding: 32rpx 0;
}
.error-banner {
  background: rgba(248, 81, 73, .15);
  border: 1rpx solid rgba(248, 81, 73, .4);
  color: #ff9090;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  margin: 24rpx 0;
  font-size: 24rpx;
}
.loading-mask {
  position: fixed;
  inset: 0;
  background: rgba(13, 20, 36, .65);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #5cb6ff;
  z-index: 99;
}