.dashboard {
  padding: 24rpx;
  background: #0d1424;
  min-height: 100vh;
  color: #e6e9f2;
}
.kpi-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-bottom: 32rpx;
}
.kpi-card {
  background: linear-gradient(135deg, rgba(47, 109, 246, .18) 0%, rgba(20, 39, 84, .55) 100%);
  border: 1rpx solid rgba(80, 140, 255, .25);
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
}
.kpi-n {
  font-size: 60rpx;
  font-weight: 700;
  color: #5cb6ff;
  text-shadow: 0 0 24rpx rgba(60, 160, 255, .35);
  line-height: 1.1;
}
.kpi-label {
  font-size: 24rpx;
  color: #c4cad8;
  margin-top: 8rpx;
}
.kpi-delta {
  font-size: 22rpx;
  color: #6c7b95;
  margin-top: 6rpx;
}
.block {
  background: rgba(20, 28, 48, .55);
  border: 1rpx solid rgba(255, 255, 255, .08);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}
.block-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 4rpx;
}
.block-sub {
  font-size: 22rpx;
  color: #8d96ad;
  margin-bottom: 20rpx;
}
.duo {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}
.duo-head {
  font-size: 26rpx;
  color: #5cb6ff;
  margin-bottom: 12rpx;
}
.bar-row {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  margin-bottom: 10rpx;
  white-space: nowrap;
}
.bar-row--wide {
  font-size: 24rpx;
  margin-bottom: 14rpx;
}
.bar-label {
  width: 90rpx;
  color: #c4cad8;
  overflow: hidden;
  text-overflow: ellipsis;
}
.bar-track {
  flex: 1;
  height: 14rpx;
  background: rgba(255, 255, 255, .06);
  border-radius: 7rpx;
  overflow: hidden;
}
.bar-fill {
  height: 100%;
  border-radius: 7rpx;
  transition: width .5s ease;
}
.bar-fill--user { background: linear-gradient(90deg, #5cb6ff, #2d7df7); }
.bar-fill--job  { background: linear-gradient(90deg, #fbb55f, #f7843a); }
.bar-n {
  width: 70rpx;
  text-align: right;
  color: #fff;
  font-weight: 600;
  margin-left: 12rpx;
}
.trend-wrap {
  max-height: 360rpx;
  overflow-y: auto;
}
.trend-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, .04);
  font-size: 22rpx;
}
.trend-date {
  width: 110rpx;
  color: #6c7b95;
}
.trend-bars {
  display: flex;
  gap: 12rpx;
  flex: 1;
}
.trend-cell {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, .06);
  color: #e6e9f2;
  font-size: 20rpx;
}
.empty {
  font-size: 22rpx;
  color: #6c7b95;
  text-align: center;
  padding: 32rpx 0;
}
.error-banner {
  background: rgba(248, 81, 73, .15);
  border: 1rpx solid rgba(248, 81, 73, .4);
  color: #ff9090;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  margin: 24rpx 0;
  font-size: 24rpx;
}
.loading-mask {
  position: fixed;
  inset: 0;
  background: rgba(13, 20, 36, .65);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #5cb6ff;
  z-index: 99;
}
