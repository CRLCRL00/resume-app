<view class="dashboard dashboard--{{mode}}">
  <!-- R58: fullscreen header (title + live clock + exit) -->
  <view wx:if="{{mode === 'fullscreen'}}" class="fs-header">
    <view class="fs-title">简历推荐 · 实时业务大屏</view>
    <view class="fs-time">{{currentTime}}</view>
    <view class="fs-exit" bindtap="toggleFullscreen">退出全屏</view>
  </view>

  <!-- R58: compact-only toggle (top-right) when device supports fullscreen -->
  <view wx:if="{{mode === 'compact' && fullscreenAvailable && showFullscreenHint}}" class="cp-toggle" bindtap="toggleFullscreen">⛶ 全屏</view>

  <!-- KPI tiles -->
  <view class="kpi-row">
    <view class="kpi-card">
      <view class="kpi-n">{{overview.users || 0}}</view>
      <view class="kpi-label">用户</view>
      <view class="kpi-delta">7d +{{overview.users_7d || 0}}</view>
    </view>
    <view class="kpi-card">
      <view class="kpi-n">{{overview.active_resumes || 0}}</view>
      <view class="kpi-label">活跃简历</view>
      <view class="kpi-delta">7d +{{overview.resumes_7d || 0}}</view>
    </view>
    <view class="kpi-card">
      <view class="kpi-n">{{overview.online_jobs || 0}}</view>
      <view class="kpi-label">在线岗位</view>
      <view class="kpi-delta">总 {{overview.total_jobs || 0}}</view>
    </view>
    <view class="kpi-card">
      <view class="kpi-n">{{overview.total_matches || 0}}</view>
      <view class="kpi-label">匹配</view>
      <view class="kpi-delta">7d {{overview.matches_7d || 0}}</view>
    </view>
  </view>

  <!-- 双栏: 用户偏好城市 (左) + 在线岗位城市 (右) -->
  <view class="block">
    <view class="block-title">城市分布</view>
    <view class="block-sub">用户偏好 vs 在线岗位</view>
    <view class="duo">
      <view class="duo-col">
        <view class="duo-head">用户 ({{cities_users.length}})</view>
        <view wx:for="{{barUsers}}" wx:key="label" class="bar-row">
          <view class="bar-label">{{item.label}}</view>
          <view class="bar-track">
            <view class="bar-fill bar-fill--user" style="width: {{item.width}}%"></view>
          </view>
          <view class="bar-n">{{item.n}}</view>
        </view>
        <view wx:if="{{!barUsers.length}}" class="empty">暂无数据</view>
      </view>
      <view class="duo-col">
        <view class="duo-head">岗位 ({{cities_jobs.length}})</view>
        <view wx:for="{{barJobs}}" wx:key="label" class="bar-row">
          <view class="bar-label">{{item.label}}</view>
          <view class="bar-track">
            <view class="bar-fill bar-fill--job" style="width: {{item.width}}%"></view>
          </view>
          <view class="bar-n">{{item.n}}</view>
        </view>
        <view wx:if="{{!barJobs.length}}" class="empty">暂无数据</view>
      </view>
    </view>
  </view>

  <!-- 薪资区间分布 -->
  <view class="block">
    <view class="block-title">薪资区间</view>
    <view class="block-sub">在线岗位分布（K/月，min）</view>
    <view wx:for="{{barSalary}}" wx:key="label" class="bar-row bar-row--wide">
      <view class="bar-label">{{item.label}}</view>
      <view class="bar-track">
        <view class="bar-fill bar-fill--job" style="width: {{item.width}}%"></view>
      </view>
      <view class="bar-n">{{item.n}}</view>
    </view>
    <view wx:if="{{!barSalary.length}}" class="empty">暂无数据</view>
  </view>

  <!-- 14天时间趋势 -->
  <view class="block">
    <view class="block-title">14 天趋势</view>
    <view class="block-sub">用户/简历/匹配 提交</view>
    <view class="trend-wrap">
      <view wx:for="{{trends}}" wx:key="date" class="trend-row">
        <view class="trend-date">{{item.date.slice(5)}}</view>
        <view class="trend-bars">
          <view class="trend-cell">U {{item.users}}</view>
          <view class="trend-cell">R {{item.resumes}}</view>
          <view class="trend-cell">M {{item.matches}}</view>
        </view>
      </view>
      <view wx:if="{{!trends.length}}" class="empty">暂无数据</view>
    </view>
  </view>

  <!-- error state -->
  <view wx:if="{{error}}" class="error-banner">{{error}}</view>

  <view wx:if="{{loading && mode === 'compact'}}" class="loading-mask">加载中…</view>
</view>