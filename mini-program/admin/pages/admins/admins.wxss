.container { padding: 24rpx; }
.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}
.input {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}
.btn-primary {
  background: #07c160;
  color: #fff;
  border-radius: 8rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 30rpx;
  margin-top: 12rpx;
}
.row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.row:last-child { border-bottom: none; }
.row-info { flex: 1; }
.openid {
  font-size: 26rpx;
  font-weight: 500;
  word-break: break-all;
}
.note {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}
.time {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}
.btn-danger {
  background: #ff4d4f;
  color: #fff;
  border-radius: 8rpx;
  padding: 12rpx 20rpx;
  font-size: 24rpx;
}
.empty {
  text-align: center;
  color: #999;
  padding: 40rpx 0;
}
