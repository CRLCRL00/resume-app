@import "../../styles/admin-common.wxss";

.container { padding: 24rpx; }
.row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.row:last-child { border-bottom: none; }
.row-info { flex: 1; }
.openid {
  font-size: 26rpx;
  font-weight: 500;
  word-break: break-all;
}
.note {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}
.time {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}
