.popup-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.6);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}
.popup-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  width: 100%;
}
.popup-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  text-align: center;
}
.popup-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  margin-bottom: 30rpx;
}
.link {
  color: #1aad19;
  text-decoration: underline;
}
.popup-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}
.btn-reject, .btn-accept {
  flex: 1;
  font-size: 30rpx;
  border-radius: 8rpx;
}
.btn-reject {
  background: #f5f5f5;
  color: #666;
}
.btn-accept {
  background: #1aad19;
  color: #fff;
}