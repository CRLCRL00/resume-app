{
  "name": "resume-app-backend",
  "version": "0.1.0",
  "private": true,
  "description": "简历推荐小程序后端",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node scripts/clear-test-rate-limit.js && node --test --test-force-exit --test-concurrency=1 tests/*.test.js",
    "check-env": "node scripts/check-env.js",
    "test:watch": "node --test --watch tests/*.test.js",
    "lint": "eslint src/ tests/",
    "db:init": "node scripts/db-init.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.10.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "uuid": "^10.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "supertest": "^7.0.0"
  }
}
