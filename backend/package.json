{
  "name": "resume-app-backend",
  "version": "0.1.0",
  "private": true,
  "description": "简历推荐小程序后端",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:pre": "npm run check:env",
    "dev": "node --watch src/index.js",
    "check:env": "node scripts/check-env.js",
    "check-env": "node scripts/check-env.js",
    "test": "node scripts/clear-test-rate-limit.js && node run-tests.js",
    "test:watch": "node --test --watch tests/*.test.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "db:init": "node scripts/db-init.js",
    "perf:bench": "node scripts/perf-bench.js",
    "perf:bench:ci": "node -e \"process.env.BENCH_P99_MS=1500; process.env.BENCH_DURATION=5000; require('./scripts/perf-bench.js')\"",
    "perf:bench:real": "node scripts/perf-bench.js --real-llm"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@sentry/node": "^10.63.0",
    "axios": "^1.7.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.4.1",
    "joi": "^17.13.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.10.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.1",
    "speakeasy": "^2.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "autocannon": "^7.15.0",
    "eslint": "^8.57.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.0.0"
  }
}