# 服务
NODE_ENV=development
PORT=3000

# 微信小程序
WX_APPID=wx_your_appid
WX_SECRET=your_secret

# JWT
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=30d

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=resume_app

# MySQL pool
DB_POOL_SIZE=10
DB_MAX_IDLE=5
DB_SLOW_QUERY_MS=1000

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# DeepSeek
DEEPSEEK_API_KEY=sk_your_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 日志
LOG_LEVEL=info

# CORS
CORS_ALLOWED_ORIGINS=https://servicewechat.com,https://fa1b04c679fe9e41-43-139-176-199.serveousercontent.com

# Slack 告警通知（Round 32-F）
# SLACK_WEBHOOK_URL: Slack incoming webhook URL. 空则只 log warn，不外发。
# SLACK_DEFAULT_CHANNEL: 默认 channel
# SLACK_HMAC_SECRET: 入站 webhook HMAC 校验密钥（空则跳过校验，仅 dev）
# ALERT_DEDUPE_TTL_MS: 同一告警多少毫秒内不重复通知（默认 3600000 = 1h）
SLACK_WEBHOOK_URL=
SLACK_DEFAULT_CHANNEL=#alerts
SLACK_HMAC_SECRET=
ALERT_DEDUPE_TTL_MS=3600000